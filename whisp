#!/usr/bin/env bash
set -euo pipefail

MODEL="large-v3"
MODEL_EXPLICIT=""    # set to "1" if user passed --model so we don't override
LANGUAGE=""
OUTPUT_DIR=""
CONDITION_ON_PREV="False"
HALLUC_SILENCE_THRESH="2"
NO_MERGE="false"
FILES=()
URLS=()

# --- Record subcommand dispatch ---
# Must happen before general arg parsing so `whisp record ...` never hits the
# file/URL parser below.
if [[ $# -gt 0 && "$1" == "record" ]]; then
  SCRIPT_DIR_EARLY="$(cd "$(dirname "$0")" && pwd)"
  if [[ ! -x "$SCRIPT_DIR_EARLY/whisp-record" ]]; then
    echo "Error: $SCRIPT_DIR_EARLY/whisp-record not found or not executable." >&2
    exit 1
  fi
  shift
  exec "$SCRIPT_DIR_EARLY/whisp-record" "$@"
fi

is_youtube_url() {
  [[ "$1" =~ ^https?://(www\.)?(youtube\.com/(watch|playlist)|youtu\.be/) ]]
}

usage() {
  cat <<'USAGE'
Usage:
  whisp [OPTIONS] [FILE...] [YOUTUBE_URL...]   Transcribe file(s) or URL(s)
  whisp record [OPTIONS]                        Live-record + transcribe
  whisp record --help                           Recording mode help

Transcribe audio/video files using OpenAI Whisper, optionally merging
with YouTube captions for better proper-noun accuracy.

Options:
  --en               Force English
  --fa               Force Farsi (Persian)
  --fi               Force Finnish
  --de               Force German
  --ru               Force Russian
  --sv               Force Swedish
  --model NAME       Whisper model (default: turbo)
  --out DIR          Output directory (default: current directory)
  --condition-prev   Enable conditioning on previous text (off by default
                     to prevent "thank you"/"yes" hallucination loops)
  --no-halluc-filter Disable hallucination silence filter
  --no-merge         Skip YouTube caption merge step
  -h, --help         Show this help

Supported formats: mp3, m4a, ogg, wav, flac, mp4, mkv, webm, avi, mov, wmv, wma, aiff, rm, qta
  Formats not natively supported by Whisper (wmv, wma, aiff, rm) are auto-converted via ffmpeg.

Examples:
  whisp recording.mp3
  whisp --en interview.m4a
  whisp --fi lecture.mp4
  whisp --de presentation.ogg

  # Local file + YouTube URL: Whisper + captions merged
  whisp video.mp4 https://www.youtube.com/watch?v=ABC123

  # URL only: download audio, transcribe, merge with captions
  whisp https://www.youtube.com/watch?v=ABC123
  whisp --en https://youtu.be/ABC123

  # Live recording: capture mic, live-transcribe, Ctrl+C to stop
  whisp record
  whisp record --fi
  whisp record --out lecture
USAGE
  exit 0
}

# --- Auto-install dependencies ---

HAS_BREW=""
if command -v brew &>/dev/null; then
  HAS_BREW=1
fi

install_prompt() {
  local pkg="$1"
  local install_cmd="$2"
  echo ""
  echo "Missing dependency: $pkg"
  echo "Install command:    $install_cmd"
  read -rp "Install now? [Y/n] " answer
  case "${answer:-Y}" in
    [Yy]*) eval "$install_cmd" ;;
    *)     echo "Aborted. Install '$pkg' manually and re-run." >&2; exit 1 ;;
  esac
}

ensure_brew() {
  [[ -n "$HAS_BREW" ]] && return
  echo ""
  echo "Homebrew not found. whisp uses brew to install dependencies on macOS."
  echo "Install command:    /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
  read -rp "Install Homebrew now? [Y/n] " answer
  case "${answer:-Y}" in
    [Yy]*)
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
      # Add brew to PATH for this session (Apple Silicon vs Intel)
      if [[ -f /opt/homebrew/bin/brew ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
      elif [[ -f /usr/local/bin/brew ]]; then
        eval "$(/usr/local/bin/brew shellenv)"
      fi
      HAS_BREW=1
      ;;
    *) echo "Aborted." >&2; exit 1 ;;
  esac
}

ensure_dep() {
  local cmd="$1"
  local brew_pkg="$2"
  local apt_pkg="${3:-$brew_pkg}"

  command -v "$cmd" &>/dev/null && return

  if [[ "$(uname)" == "Darwin" ]]; then
    ensure_brew
    install_prompt "$brew_pkg" "brew install $brew_pkg"
  elif command -v apt-get &>/dev/null; then
    install_prompt "$apt_pkg" "sudo apt-get update && sudo apt-get install -y $apt_pkg"
  else
    echo "Error: '$cmd' not found and no supported package manager detected." >&2
    exit 1
  fi

  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: '$cmd' still not found after install." >&2
    exit 1
  fi
}

# --- Argument parsing ---

while [[ $# -gt 0 ]]; do
  case "$1" in
    --en)               LANGUAGE="en"; shift ;;
    --fa)               LANGUAGE="fa"; shift ;;
    --fi)               LANGUAGE="fi"; shift ;;
    --de)               LANGUAGE="de"; shift ;;
    --ru)               LANGUAGE="ru"; shift ;;
    --sv)               LANGUAGE="sv"; shift ;;
    --model)            MODEL="$2"; MODEL_EXPLICIT="1"; shift 2 ;;
    --out)              OUTPUT_DIR="$2"; shift 2 ;;
    --condition-prev)   CONDITION_ON_PREV="True"; shift ;;
    --no-halluc-filter) HALLUC_SILENCE_THRESH="0"; shift ;;
    --no-merge)         NO_MERGE="true"; shift ;;
    -h|--help) usage ;;
    -*)        echo "Unknown option: $1" >&2; exit 1 ;;
    *)
      if is_youtube_url "$1"; then
        URLS+=("$1")
      else
        FILES+=("$1")
      fi
      shift
      ;;
  esac
done

# Default model is now large-v3 (set above). The auto-upgrade-for-non-English
# logic became a no-op once we made large-v3 the global default. Kept the
# MODEL_EXPLICIT mechanism so --model turbo still works to opt out for
# English speech where turbo is fine and ~3x faster.

if [[ ${#FILES[@]} -eq 0 && ${#URLS[@]} -eq 0 ]]; then
  echo "Error: No input files or URLs specified." >&2
  echo "Run 'whisp --help' for usage." >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Dependency checks (auto-install if missing)
ensure_dep ffmpeg ffmpeg
ensure_dep whisper openai-whisper

if [[ ${#URLS[@]} -gt 0 ]]; then
  ensure_dep yt-dlp yt-dlp
fi

# Determine subtitle language code
SUB_LANG="${LANGUAGE:-en}"

# Validate file+URL pairing
if [[ ${#FILES[@]} -gt 0 && ${#URLS[@]} -gt 0 ]]; then
  if [[ ${#FILES[@]} -ne ${#URLS[@]} ]]; then
    echo "Error: File/URL count mismatch: ${#FILES[@]} file(s) and ${#URLS[@]} URL(s)." >&2
    echo "  Provide one URL per file, or URLs only (audio will be downloaded)." >&2
    exit 1
  fi
fi

# If URLs only (no local files), download audio first
if [[ ${#FILES[@]} -eq 0 && ${#URLS[@]} -gt 0 ]]; then
  if [[ -n "$OUTPUT_DIR" ]]; then
    dl_dir="$OUTPUT_DIR"
  else
    dl_dir="$(pwd)"
  fi
  mkdir -p "$dl_dir"

  for url in "${URLS[@]}"; do
    echo "=== Downloading audio: $url ==="
    # Get video title for readable filename
    video_title=$(yt-dlp --print "%(title)s" "$url" 2>/dev/null | \
      tr '/:*?"<>|\\' '-' | sed 's/  */ /g; s/^ *//; s/ *$//')
    video_id=$(yt-dlp --print id "$url" 2>/dev/null)
    if [[ -z "$video_title" ]]; then
      video_title="$video_id"
    fi
    yt-dlp -f bestaudio --extract-audio --audio-format m4a \
      -o "$dl_dir/${video_title}.%(ext)s" "$url"
    dl_file="$dl_dir/${video_title}.m4a"
    if [[ ! -f "$dl_file" ]]; then
      # Fallback: try with video ID
      yt-dlp -f bestaudio --extract-audio --audio-format m4a \
        -o "$dl_dir/${video_id}.%(ext)s" "$url" 2>/dev/null || true
      dl_file="$dl_dir/${video_id}.m4a"
    fi
    if [[ ! -f "$dl_file" ]]; then
      echo "Error: Downloaded audio not found" >&2
      exit 1
    fi
    FILES+=("$dl_file")
    echo "    Downloaded: $dl_file"
    echo ""
  done
fi

SUPPORTED_EXTENSIONS="mp3|m4a|ogg|wav|flac|mp4|mkv|webm|avi|mov|wmv|wma|aiff|rm|qta"

for idx in "${!FILES[@]}"; do
  file="${FILES[$idx]}"
  # Determine paired URL (if any)
  paired_url=""
  if [[ ${#URLS[@]} -gt 0 && $idx -lt ${#URLS[@]} ]]; then
    paired_url="${URLS[$idx]}"
  fi

  if [[ ! -f "$file" ]]; then
    echo "Error: File not found: $file" >&2
    continue
  fi

  ext="${file##*.}"
  ext="$(printf '%s' "$ext" | tr '[:upper:]' '[:lower:]')"
  if [[ ! "$ext" =~ ^($SUPPORTED_EXTENSIONS)$ ]]; then
    echo "Error: Unsupported file type: .$ext ($file)" >&2
    echo "  Supported formats: mp3, m4a, ogg, wav, flac, mp4, mkv, webm, avi, mov, wmv, wma, aiff, rm, qta" >&2
    continue
  fi

  # Auto-convert formats not natively supported by Whisper
  # qta → m4a (stream copy), wmv/wma/aiff/rm → mp4/m4a (transcode)
  case "$ext" in
    qta)
      m4a_file="${file%.qta}.m4a"
      if [[ ! -f "$m4a_file" ]]; then
        echo "--- Converting .qta (spatial audio) to .m4a ---"
        ffmpeg -y -i "$file" -map 0:0 -c copy "$m4a_file" 2>/dev/null
        if [[ ! -f "$m4a_file" ]]; then
          echo "Error: Failed to convert $file to m4a" >&2
          continue
        fi
        echo "    Converted: $m4a_file"
      fi
      file="$m4a_file"
      ext="m4a"
      ;;
    wmv)
      mp4_file="${file%.wmv}.mp4"
      if [[ ! -f "$mp4_file" ]]; then
        echo "--- Converting .wmv to .mp4 ---"
        ffmpeg -y -i "$file" -c:v libx264 -c:a aac "$mp4_file" 2>/dev/null
        if [[ ! -f "$mp4_file" ]]; then
          echo "Error: Failed to convert $file to mp4" >&2
          continue
        fi
        echo "    Converted: $mp4_file"
      fi
      file="$mp4_file"
      ext="mp4"
      ;;
    wma)
      m4a_file="${file%.wma}.m4a"
      if [[ ! -f "$m4a_file" ]]; then
        echo "--- Converting .wma to .m4a ---"
        ffmpeg -y -i "$file" -c:a aac "$m4a_file" 2>/dev/null
        if [[ ! -f "$m4a_file" ]]; then
          echo "Error: Failed to convert $file to m4a" >&2
          continue
        fi
        echo "    Converted: $m4a_file"
      fi
      file="$m4a_file"
      ext="m4a"
      ;;
    aiff)
      wav_file="${file%.aiff}.wav"
      if [[ ! -f "$wav_file" ]]; then
        echo "--- Converting .aiff to .wav ---"
        ffmpeg -y -i "$file" "$wav_file" 2>/dev/null
        if [[ ! -f "$wav_file" ]]; then
          echo "Error: Failed to convert $file to wav" >&2
          continue
        fi
        echo "    Converted: $wav_file"
      fi
      file="$wav_file"
      ext="wav"
      ;;
    rm)
      mp4_file="${file%.rm}.mp4"
      if [[ ! -f "$mp4_file" ]]; then
        echo "--- Converting .rm (RealMedia) to .mp4 ---"
        ffmpeg -y -i "$file" -c:v libx264 -c:a aac "$mp4_file" 2>/dev/null
        if [[ ! -f "$mp4_file" ]]; then
          echo "Error: Failed to convert $file to mp4" >&2
          continue
        fi
        echo "    Converted: $mp4_file"
      fi
      file="$mp4_file"
      ext="mp4"
      ;;
  esac

  if [[ -n "$OUTPUT_DIR" ]]; then
    outdir="$OUTPUT_DIR"
  else
    outdir="$(pwd)"
  fi
  mkdir -p "$outdir"

  echo "=== Transcribing: $file ==="
  echo "    Model: $MODEL"
  if [[ -n "$LANGUAGE" ]]; then
    echo "    Language: $LANGUAGE"
  else
    echo "    Language: auto-detect"
  fi
  echo "    Output: $outdir"
  echo "    Condition on previous text: $CONDITION_ON_PREV"
  if [[ "$HALLUC_SILENCE_THRESH" != "0" ]]; then
    echo "    Hallucination silence threshold: ${HALLUC_SILENCE_THRESH}s"
  fi
  if [[ -n "$paired_url" ]]; then
    echo "    YouTube URL: $paired_url"
    echo "    Word timestamps: enabled (for merge)"
  fi
  echo ""

  # Detect machine identity and pick the best ML device. On Apple Silicon
  # this MUST use Metal GPU (MPS) — defaulting to CPU on an M-series Mac is
  # "doing it the wrong way around" (Esa's words). large-v3 on MPS is ~5-10x
  # faster than CPU and that's the whole reason for having a Mac.
  # See: feedback_apple_silicon_first.md in mediabank/memory.
  # Override with WHISP_DEVICE=cpu if MPS hits a correctness issue.
  if [[ -z "${WHISP_DEVICE:-}" ]]; then
    WHISP_DEVICE="$(python3 - <<'PYEOF'
import platform, sys
try:
    import torch
except Exception:
    print("cpu"); sys.exit(0)
is_apple_silicon = (platform.system() == "Darwin" and platform.machine() == "arm64")
if is_apple_silicon and torch.backends.mps.is_available() and torch.backends.mps.is_built():
    print("mps")
elif torch.cuda.is_available():
    print("cuda")
else:
    print("cpu")
PYEOF
)"
  fi
  # Friendly label for the log
  case "$WHISP_DEVICE" in
    mps)  echo "    Device: mps  (Apple Silicon Metal GPU)" ;;
    cuda) echo "    Device: cuda" ;;
    cpu)  echo "    Device: cpu  (no MPS/CUDA — inference will be slow)" ;;
    *)    echo "    Device: $WHISP_DEVICE" ;;
  esac

  WHISPER_ARGS=(
    "$file"
    --model "$MODEL"
    --device "$WHISP_DEVICE"
    --output_format all
    --output_dir "$outdir"
    --condition_on_previous_text "$CONDITION_ON_PREV"
  )

  # On MPS, large-v2/v3 produces NaN tensors mid-transcription with the
  # default float16 mixed-precision setting (PyTorch MPS precision bug).
  # Forcing fp32 sidesteps the crash. Slight speed cost vs fp16 but still
  # 5x+ faster than CPU.
  if [[ "$WHISP_DEVICE" == "mps" ]]; then
    WHISPER_ARGS+=(--fp16 False)
  fi

  if [[ -n "$LANGUAGE" ]]; then
    WHISPER_ARGS+=(--language "$LANGUAGE")
  fi

  if [[ "$HALLUC_SILENCE_THRESH" != "0" ]]; then
    WHISPER_ARGS+=(--hallucination_silence_threshold "$HALLUC_SILENCE_THRESH")
  fi

  # Enable word-level timestamps when merging with YouTube captions
  if [[ -n "$paired_url" ]]; then
    WHISPER_ARGS+=(--word_timestamps True)
  fi

  # Start YouTube caption download in parallel with Whisper
  yt_captions_pid=""
  yt_subs_dir=""
  yt_captions_log=""
  if [[ -n "$paired_url" && "$NO_MERGE" != "true" ]]; then
    yt_subs_dir="$outdir/.yt-subs"
    mkdir -p "$yt_subs_dir"
    yt_captions_log="$yt_subs_dir/.download.log"

    echo "--- YouTube captions: downloading in background ---"
    (
      video_id=$(yt-dlp --print id "$paired_url" 2>/dev/null)
      echo "$video_id" > "$yt_subs_dir/.video_id"

      # Try manual captions first, then auto-generated
      for sub_flag in --write-subs --write-auto-subs; do
        yt-dlp "$sub_flag" --sub-langs "$SUB_LANG" --sub-format vtt \
          --skip-download -o "$yt_subs_dir/%(id)s" "$paired_url" 2>/dev/null || true
        vtt_file="$yt_subs_dir/${video_id}.${SUB_LANG}.vtt"
        if [[ -f "$vtt_file" ]]; then
          echo "OK $sub_flag $vtt_file" > "$yt_captions_log"
          exit 0
        fi
      done

      # Fallback: find any VTT that was downloaded
      vtt_file=$(find "$yt_subs_dir" -name "${video_id}*.vtt" -print -quit 2>/dev/null || true)
      if [[ -n "$vtt_file" && -f "$vtt_file" ]]; then
        echo "OK fallback $vtt_file" > "$yt_captions_log"
      else
        echo "FAIL" > "$yt_captions_log"
      fi
    ) &
    yt_captions_pid=$!
    echo "    Caption download PID: $yt_captions_pid"
    echo ""
  fi

  # === Engine dispatch (added 2026-05-27) ===
  # Prefer mlx-whisper on Apple Silicon: ~3x less memory, ~3x faster.
  # Detection via apple-report --json — `hardware.chip` startswith "Apple" on M-series.
  # Falls through to openai-whisper if: not Apple Silicon, mlx_whisper not in PATH,
  # or apple-report missing. Both engines produce the same output formats so the
  # downstream deloop / merge steps don't need to care which ran.
  USE_MLX=0
  if command -v apple-report >/dev/null 2>&1 && command -v mlx_whisper >/dev/null 2>&1; then
    if apple-report --json 2>/dev/null | python3 -c 'import json,sys; sys.exit(0 if json.load(sys.stdin).get("hardware",{}).get("chip","").startswith("Apple") else 1)' 2>/dev/null; then
      USE_MLX=1
    fi
  fi

  if [[ "$USE_MLX" == "1" ]]; then
    # Translate openai-whisper model name → mlx-community HuggingFace path
    case "$MODEL" in
      tiny)                  MLX_MODEL=mlx-community/whisper-tiny-mlx ;;
      base)                  MLX_MODEL=mlx-community/whisper-base-mlx ;;
      small)                 MLX_MODEL=mlx-community/whisper-small-mlx ;;
      medium)                MLX_MODEL=mlx-community/whisper-medium-mlx ;;
      large-v3)              MLX_MODEL=mlx-community/whisper-large-v3-mlx ;;
      turbo|large-v3-turbo)  MLX_MODEL=mlx-community/whisper-large-v3-turbo ;;
      *)                     MLX_MODEL=mlx-community/whisper-large-v3-turbo ;;
    esac

    MLX_ARGS=(
      "$file"
      --model "$MLX_MODEL"
      --output-format all
      --output-dir "$outdir"
      # Always pass condition-on-previous-text — mlx-whisper defaults to True
      # which causes hallucination loops ("se on se, että se on se, että..."
      # in Finnish, observed 2026-05-27). whisp's CONDITION_ON_PREV defaults
      # to "False" which is what we want.
      --condition-on-previous-text "$CONDITION_ON_PREV"
    )
    [[ -n "$LANGUAGE" ]] && MLX_ARGS+=(--language "$LANGUAGE")
    if [[ "$HALLUC_SILENCE_THRESH" != "0" ]]; then
      MLX_ARGS+=(--hallucination-silence-threshold "$HALLUC_SILENCE_THRESH")
    fi
    # Always emit word timestamps: downstream tools (sentence/word chopping,
    # voice isolation) need per-word timing, and a local-file transcript must be
    # just as choppable as a paired-URL one. (Previously gated to paired_url,
    # which silently produced word-less JSON for local files.)
    MLX_ARGS+=(--word-timestamps True)

    echo "    Engine: mlx-whisper ($MLX_MODEL)"

    if ! mlx_whisper "${MLX_ARGS[@]}"; then
      echo "Error: mlx-whisper failed to transcribe: $file" >&2
      if [[ -n "$yt_captions_pid" ]]; then
        kill "$yt_captions_pid" 2>/dev/null || true
        wait "$yt_captions_pid" 2>/dev/null || true
      fi
      continue
    fi
  else
    echo "    Engine: openai-whisper ($MODEL)"
    if ! whisper "${WHISPER_ARGS[@]}"; then
      echo "Error: Whisper failed to transcribe: $file" >&2
      if [[ -n "$yt_captions_pid" ]]; then
        kill "$yt_captions_pid" 2>/dev/null || true
        wait "$yt_captions_pid" 2>/dev/null || true
      fi
      continue
    fi
  fi

  basename="${file##*/}"
  basename="${basename%.*}"

  # Post-process: strip hallucination loops (3+ consecutive identical segments)
  json_out="$outdir/$basename.json"
  if [[ -f "$json_out" ]]; then
    echo ""
    echo "--- Deloop: checking for hallucination loops ---"
    python3 "$SCRIPT_DIR/whisp-deloop" "$basename" "$outdir"
  else
    echo ""
    echo "Warning: No JSON output found, skipping deloop." >&2
  fi

  # YouTube caption merge step — wait for background download to finish
  if [[ -n "$yt_captions_pid" ]]; then
    echo ""
    echo "--- YouTube captions: waiting for download to finish ---"
    wait "$yt_captions_pid" 2>/dev/null || true

    if [[ -f "$yt_captions_log" ]]; then
      yt_result=$(cat "$yt_captions_log")
      if [[ "$yt_result" == FAIL ]]; then
        echo "    Warning: No captions found for $paired_url, skipping merge." >&2
      else
        # Extract vtt_file path (third field)
        vtt_file=$(echo "$yt_result" | awk '{print $3}')
        sub_flag=$(echo "$yt_result" | awk '{print $2}')
        echo "    Captions ($sub_flag): $vtt_file"
        if [[ -n "$vtt_file" && -f "$vtt_file" ]]; then
          echo ""
          echo "--- Merge: combining Whisper + YouTube captions ---"
          python3 "$SCRIPT_DIR/whisp-merge" "$basename" "$outdir" "$vtt_file"
        else
          echo "    Warning: Caption file not found, skipping merge." >&2
        fi
      fi
      rm -f "$yt_captions_log"
    else
      echo "    Warning: Caption download produced no result, skipping merge." >&2
    fi
  fi

  echo ""
  echo "Done: $file"
  echo "Output files:"
  for ext in txt srt vtt tsv json; do
    target="$outdir/$basename.$ext"
    if [[ -f "$target" ]]; then
      echo "  $target"
    fi
  done
  echo ""
done

# --- Archive to whisp-transcripts repo ---

TRANSCRIPTS_REPO="$HOME/work/whisp-transcripts"
if [[ -d "$TRANSCRIPTS_REPO/.git" ]]; then
  echo ""
  echo "=== Archiving to whisp-transcripts ==="
  cd "$TRANSCRIPTS_REPO"
  git pull --rebase --autostash 2>/dev/null || true

  archived=0
  for idx in "${!FILES[@]}"; do
    file="${FILES[$idx]}"
    basename="${file##*/}"
    basename="${basename%.*}"

    if [[ -n "$OUTPUT_DIR" ]]; then
      outdir="$OUTPUT_DIR"
    else
      outdir="$(cd "$(dirname "$file")" && pwd)"
    fi

    # Check if transcript files exist
    txt_file="$outdir/$basename.txt"
    [[ -f "$txt_file" ]] || continue

    # Create transcript directory (same format as whisp-worker)
    today="$(date +%Y-%m-%d)"
    slug="$(echo "$basename" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g; s/--*/-/g; s/^-//; s/-$//' | head -c 80)"
    transcript_dir="$TRANSCRIPTS_REPO/transcripts/${today}_${slug}"
    [[ -d "$transcript_dir" ]] && transcript_dir="${transcript_dir}_$(date +%s)"
    mkdir -p "$transcript_dir"

    # Copy transcript files
    for ext in txt json srt vtt tsv; do
      src="$outdir/$basename.$ext"
      [[ -f "$src" ]] && cp "$src" "$transcript_dir/transcript.$ext"
    done

    # Generate metadata
    duration_secs=$(ffprobe -v quiet -show_entries format=duration -of csv=p=0 "$file" 2>/dev/null | cut -d. -f1 || echo "0")
    cat > "$transcript_dir/metadata.yaml" <<METAEOF
title: "$(echo "$basename" | sed 's/"/\\"/g')"
source_file: "$(basename "$file")"
duration_seconds: ${duration_secs:-0}
whisper_model: $MODEL
language: ${LANGUAGE:-auto}
transcribed_date: "$today"
source: local

concepts: []
people: []
domains: []
METAEOF

    echo "  Archived: $basename -> $(basename "$transcript_dir")"
    ((archived++)) || true
  done

  if [[ "$archived" -gt 0 ]]; then
    cd "$TRANSCRIPTS_REPO"
    git add transcripts/
    git commit -m "transcript: $archived local file(s) from $(hostname -s)"
    git push && echo "Pushed $archived transcript(s) to repo." || echo "Push failed — will retry next time."
  else
    echo "  No transcripts to archive."
  fi
else
