#!/usr/bin/env python3
"""Merge YouTube captions with Whisper transcription for better accuracy.

YouTube auto-captions often get proper nouns right where Whisper struggles.
Whisper has better grammar, punctuation, and timing. This script combines
the best of both by replacing low-confidence Whisper words with YouTube
alternatives, especially proper nouns.

Usage: whisp-merge <basename> <output_dir> <youtube_vtt_path>
"""

import json
import sys
import os
import re
from bisect import bisect_left, bisect_right
from difflib import SequenceMatcher


def parse_vtt_timestamp(ts_str):
    """Parse VTT timestamp 'HH:MM:SS.mmm' to seconds."""
    parts = ts_str.split(':')
    if len(parts) == 3:
        h, m, rest = parts
    elif len(parts) == 2:
        h = 0
        m, rest = parts
    else:
        return 0.0
    s_parts = rest.split('.')
    s = float(s_parts[0])
    ms = float('0.' + s_parts[1]) if len(s_parts) > 1 else 0.0
    return int(h) * 3600 + int(m) * 60 + s + ms


def parse_youtube_vtt(vtt_path):
    """Parse YouTube VTT with <c> word-level timestamps.

    YouTube auto-subs use a rolling format where each cue block has:
    - Line 1: previous cue text (plain, no timestamps) — skip this
    - Line 2: new words with <HH:MM:SS.mmm><c> word</c> tags

    Echo cues (10ms duration) just repeat text without new words — skip these.

    Returns list of {'word': str, 'start': float} sorted by start time.
    """
    with open(vtt_path, encoding='utf-8') as f:
        content = f.read()

    words = []
    seen_timestamps = set()

    # Split into cue blocks (separated by blank lines)
    blocks = re.split(r'\n\n+', content)

    for block in blocks:
        lines = block.strip().split('\n')

        # Find the timing line
        timing_line = None
        timing_idx = -1
        for i, line in enumerate(lines):
            if '-->' in line:
                timing_line = line
                timing_idx = i
                break

        if timing_line is None:
            continue

        # Parse cue start/end times
        timing_match = re.match(
            r'(\d{2}:\d{2}:\d{2}\.\d{3})\s+-->\s+(\d{2}:\d{2}:\d{2}\.\d{3})',
            timing_line
        )
        if not timing_match:
            continue

        cue_start = parse_vtt_timestamp(timing_match.group(1))
        cue_end = parse_vtt_timestamp(timing_match.group(2))

        # Skip echo cues (10ms or less duration)
        if cue_end - cue_start <= 0.015:
            continue

        # Get content lines after the timing line
        content_lines = lines[timing_idx + 1:]
        if not content_lines:
            continue

        # YouTube rolling format: line 1 is previous text (plain), line 2 has new words
        # If there are 2 content lines, the one with <c> tags (or timestamps) is the new one
        # If there's only 1 line, it's new content
        target_line = None
        for cl in content_lines:
            if '<c>' in cl or re.search(r'<\d{2}:\d{2}:\d{2}\.\d{3}>', cl):
                target_line = cl
                break

        if target_line is None:
            # Single plain line with no timestamps — first word gets cue_start
            for cl in content_lines:
                cl = cl.strip()
                if cl and cl != ' ':
                    plain_words = cl.split()
                    if plain_words:
                        key = (round(cue_start, 3), plain_words[0].lower())
                        if key not in seen_timestamps:
                            seen_timestamps.add(key)
                            words.append({
                                'word': plain_words[0],
                                'start': cue_start,
                            })
            continue

        # Parse the line with <c> tags
        # Format: firstword<TS><c> word2</c><TS><c> word3</c>...
        # First word timestamp = cue_start
        # Extract first word (before any < tag)
        first_word_match = re.match(r'^([^<]+)', target_line)
        if first_word_match:
            first_word = first_word_match.group(1).strip()
            if first_word:
                key = (round(cue_start, 3), first_word.lower())
                if key not in seen_timestamps:
                    seen_timestamps.add(key)
                    words.append({
                        'word': first_word,
                        'start': cue_start,
                    })

        # Extract timestamped words: <HH:MM:SS.mmm><c> word</c>
        pattern = r'<(\d{2}:\d{2}:\d{2}\.\d{3})><c>\s*([^<]*?)\s*</c>'
        for match in re.finditer(pattern, target_line):
            ts = parse_vtt_timestamp(match.group(1))
            word = match.group(2).strip()
            if word:
                key = (round(ts, 3), word.lower())
                if key not in seen_timestamps:
                    seen_timestamps.add(key)
                    words.append({
                        'word': word,
                        'start': ts,
                    })

    # Sort by timestamp
    words.sort(key=lambda w: w['start'])
    return words


def looks_like_proper_noun(word):
    """Check if a word looks like a proper noun (starts with uppercase, not sentence-start)."""
    if not word:
        return False
    # Proper nouns: capitalized, not all-caps, not common sentence starters
    clean = re.sub(r'[^a-zA-Z]', '', word)
    if not clean:
        return False
    return clean[0].isupper() and not clean.isupper() and len(clean) > 1


def find_overlapping_yt_words(yt_words, yt_starts, start, end, tolerance=0.5):
    """Find YouTube words that overlap a given time range using binary search."""
    left = bisect_left(yt_starts, start - tolerance)
    right = bisect_right(yt_starts, end + tolerance)
    return yt_words[left:right]


def words_similar(w1, w2):
    """Check if two words are similar enough to be the same word."""
    w1_clean = re.sub(r'[^a-z]', '', w1.lower())
    w2_clean = re.sub(r'[^a-z]', '', w2.lower())
    if not w1_clean or not w2_clean:
        return False
    if w1_clean == w2_clean:
        return True
    # Allow for minor differences (e.g., "dep" vs "de", "Palma" vs "palma")
    ratio = SequenceMatcher(None, w1_clean, w2_clean).ratio()
    return ratio >= 0.6


def merge_word_level(whisper_data, yt_words):
    """Merge at word level using Whisper word timestamps and probabilities."""
    yt_starts = [w['start'] for w in yt_words]
    substitutions = []
    yt_used = 0
    whisper_kept = 0

    for segment in whisper_data.get('segments', []):
        if 'words' not in segment:
            continue

        new_words = []
        for wword in segment['words']:
            w_text = wword.get('word', '')
            w_start = wword.get('start', 0)
            w_end = wword.get('end', 0)
            w_prob = wword.get('probability', 1.0)

            # Find nearby YouTube words
            nearby = find_overlapping_yt_words(yt_words, yt_starts, w_start, w_end)

            best_yt = None
            for yw in nearby:
                if words_similar(w_text, yw['word']):
                    best_yt = yw
                    break

            if best_yt is None:
                new_words.append(wword)
                whisper_kept += 1
                continue

            yt_text = best_yt['word']

            # Decision logic
            use_youtube = False

            if w_prob >= 0.7:
                # High confidence Whisper — only override for proper noun fix
                if looks_like_proper_noun(yt_text) and not looks_like_proper_noun(w_text.strip()):
                    use_youtube = True
            else:
                # Low confidence — prefer YouTube, especially for proper nouns
                if looks_like_proper_noun(yt_text):
                    use_youtube = True
                elif w_prob < 0.4:
                    # Very low confidence — take YouTube version
                    use_youtube = True

            if use_youtube:
                # Preserve Whisper's leading/trailing whitespace
                leading = ''
                trailing = ''
                if w_text and w_text[0] == ' ':
                    leading = ' '
                if w_text and w_text[-1] == ' ':
                    trailing = ' '

                old_text = w_text.strip()
                merged_word = dict(wword)
                merged_word['word'] = leading + yt_text + trailing
                merged_word['_yt_source'] = True
                new_words.append(merged_word)
                substitutions.append((old_text, yt_text, w_prob))
                yt_used += 1
            else:
                new_words.append(wword)
                whisper_kept += 1

        # Rebuild segment text from merged words
        segment['words'] = new_words
        segment['text'] = ''.join(w.get('word', '') for w in new_words)

    # Rebuild full text
    whisper_data['text'] = ''.join(
        seg.get('text', '') for seg in whisper_data.get('segments', [])
    )

    return substitutions, whisper_kept, yt_used


def merge_segment_level(whisper_data, yt_words):
    """Fallback merge at segment level using avg_logprob and SequenceMatcher."""
    yt_starts = [w['start'] for w in yt_words]
    substitutions = []
    yt_used = 0
    whisper_kept = 0

    for segment in whisper_data.get('segments', []):
        seg_start = segment.get('start', 0)
        seg_end = segment.get('end', 0)
        avg_logprob = segment.get('avg_logprob', 0)

        # Find YouTube words in this segment's time range
        nearby = find_overlapping_yt_words(yt_words, yt_starts, seg_start, seg_end)
        if not nearby:
            whisper_kept += 1
            continue

        yt_text_words = [w['word'] for w in nearby]
        whisper_text = segment.get('text', '').strip()
        whisper_words = whisper_text.split()

        if not whisper_words:
            whisper_kept += 1
            continue

        # Use SequenceMatcher to align words
        matcher = SequenceMatcher(None,
                                  [w.lower() for w in whisper_words],
                                  [w.lower() for w in yt_text_words])

        new_words = list(whisper_words)
        segment_subs = []

        for tag, i1, i2, j1, j2 in matcher.get_opcodes():
            if tag == 'replace':
                # Only substitute when words are similar (same word, different casing)
                for wi, yi in zip(range(i1, i2), range(j1, j2)):
                    if wi < len(new_words) and yi < len(yt_text_words):
                        yt_w = yt_text_words[yi]
                        wh_w = new_words[wi]
                        if words_similar(wh_w, yt_w) and looks_like_proper_noun(yt_w):
                            segment_subs.append((wh_w, yt_w, avg_logprob))
                            new_words[wi] = yt_w
                            yt_used += 1
                        else:
                            whisper_kept += 1
            elif tag == 'equal':
                # Check for capitalization fixes even on "equal" words
                for wi, yi in zip(range(i1, i2), range(j1, j2)):
                    if wi < len(new_words) and yi < len(yt_text_words):
                        yt_w = yt_text_words[yi]
                        if looks_like_proper_noun(yt_w) and not looks_like_proper_noun(new_words[wi]):
                            segment_subs.append((new_words[wi], yt_w, avg_logprob))
                            new_words[wi] = yt_w
                            yt_used += 1
                        else:
                            whisper_kept += 1

        if segment_subs:
            segment['text'] = ' ' + ' '.join(new_words)
            substitutions.extend(segment_subs)

    # Rebuild full text
    whisper_data['text'] = ''.join(
        seg.get('text', '') for seg in whisper_data.get('segments', [])
    )

    return substitutions, whisper_kept, yt_used


# --- Output writers (same as whisp-deloop) ---

def format_ts_srt(seconds):
    h = int(seconds // 3600)
    m = int((seconds % 3600) // 60)
    s = int(seconds % 60)
    ms = int((seconds % 1) * 1000)
    return f"{h:02d}:{m:02d}:{s:02d},{ms:03d}"


def format_ts_vtt(seconds):
    h = int(seconds // 3600)
    m = int((seconds % 3600) // 60)
    s = int(seconds % 60)
    ms = int((seconds % 1) * 1000)
    return f"{h:02d}:{m:02d}:{s:02d}.{ms:03d}"


def write_txt(segments, path):
    with open(path, 'w') as f:
        for seg in segments:
            f.write(seg.get('text', '').strip() + '\n')


def write_srt(segments, path):
    with open(path, 'w') as f:
        for i, seg in enumerate(segments, 1):
            start = format_ts_srt(seg['start'])
            end = format_ts_srt(seg['end'])
            text = seg.get('text', '').strip()
            f.write(f"{i}\n{start} --> {end}\n{text}\n\n")


def write_vtt(segments, path):
    with open(path, 'w') as f:
        f.write("WEBVTT\n\n")
        for seg in segments:
            start = format_ts_vtt(seg['start'])
            end = format_ts_vtt(seg['end'])
            text = seg.get('text', '').strip()
            f.write(f"{start} --> {end}\n{text}\n\n")


def write_tsv(segments, path):
    with open(path, 'w') as f:
        f.write("start\tend\ttext\n")
        for seg in segments:
            start = int(seg['start'] * 1000)
            end = int(seg['end'] * 1000)
            text = seg.get('text', '').strip()
            f.write(f"{start}\t{end}\t{text}\n")


def write_json(data, segments, path):
    data['segments'] = segments
    with open(path, 'w') as f:
        json.dump(data, f, indent=2, ensure_ascii=False)


def main():
    if len(sys.argv) != 4:
        print(f"Usage: {sys.argv[0]} <basename> <output_dir> <youtube_vtt_path>",
              file=sys.stderr)
        sys.exit(1)

    basename = sys.argv[1]
    output_dir = sys.argv[2]
    vtt_path = sys.argv[3]

    json_path = os.path.join(output_dir, basename + '.json')

    if not os.path.exists(json_path):
        print(f"  Error: {json_path} not found", file=sys.stderr)
        sys.exit(1)

    if not os.path.exists(vtt_path):
        print(f"  Error: {vtt_path} not found", file=sys.stderr)
        sys.exit(1)

    # Load Whisper JSON
    with open(json_path) as f:
        whisper_data = json.load(f)

    # Language mismatch check
    whisper_lang = whisper_data.get('language', '')
    vtt_basename = os.path.basename(vtt_path)
    vtt_lang_match = re.search(r'\.([a-z]{2})\.vtt$', vtt_basename)
    vtt_lang = vtt_lang_match.group(1) if vtt_lang_match else ''

    if whisper_lang and vtt_lang and whisper_lang != vtt_lang:
        print(f"  Warning: Language mismatch — Whisper detected '{whisper_lang}', "
              f"captions are '{vtt_lang}'. Skipping merge.")
        return

    # Parse YouTube VTT
    yt_words = parse_youtube_vtt(vtt_path)
    if not yt_words:
        print("  Warning: No words extracted from YouTube captions. Skipping merge.")
        return

    print(f"  YouTube captions: {len(yt_words)} words extracted")

    # Check if word-level timestamps exist
    has_word_timestamps = any(
        'words' in seg for seg in whisper_data.get('segments', [])
    )

    if has_word_timestamps:
        print("  Merge mode: word-level (Whisper has word timestamps)")
        substitutions, whisper_kept, yt_used = merge_word_level(whisper_data, yt_words)
    else:
        print("  Merge mode: segment-level (no word timestamps)")
        substitutions, whisper_kept, yt_used = merge_segment_level(whisper_data, yt_words)

    segments = whisper_data.get('segments', [])

    if not substitutions:
        print("  No substitutions made — Whisper output unchanged.")
        return

    # Report
    print(f"  Substitutions: {len(substitutions)}")
    print(f"  Sources: Whisper={whisper_kept}, YouTube={yt_used}")

    # Show substitutions (up to 20)
    shown = substitutions[:20]
    for old, new, prob in shown:
        prob_str = f"p={prob:.2f}" if isinstance(prob, float) and prob >= 0 else f"logp={prob:.2f}"
        print(f"    \"{old}\" -> \"{new}\" ({prob_str})")
    if len(substitutions) > 20:
        print(f"    ... and {len(substitutions) - 20} more")

    # Regenerate all output files
    write_json(whisper_data, segments, os.path.join(output_dir, basename + '.json'))
    write_txt(segments, os.path.join(output_dir, basename + '.txt'))
    write_srt(segments, os.path.join(output_dir, basename + '.srt'))
    write_vtt(segments, os.path.join(output_dir, basename + '.vtt'))
    write_tsv(segments, os.path.join(output_dir, basename + '.tsv'))

    print("  Output files regenerated with merged content.")


if __name__ == '__main__':
    main()
